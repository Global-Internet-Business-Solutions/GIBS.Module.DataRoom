@using GIBS.Module.DataRoom.Services
@using GIBS.Module.DataRoom.Models
@using Oqtane.Models
@using System.Globalization
@using System.Resources
@using Microsoft.Extensions.Localization

@namespace GIBS.Module.DataRoom
@inherits ModuleBase
@inject IDataRoomService DataRoomService
@inject IDataRoomActivityLogService ActivityLogService
@inject IDataRoomSubscriptionService SubscriptionService
@inject IFolderService FolderService
@inject IFileService FileService
@inject ISettingService SettingService
@inject INotificationService NotificationService
@inject IStringLocalizer<Index> Localizer
@inject IJSRuntime JSRuntime



@if (!_initialized)
{
    <div class="text-center py-3">
        <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
    </div>
}


else if (_dataRoom == null)
{
    <div class="alert alert-info">
        <p class="mb-0">@Localizer["NoAccessMessage"]</p>
        @if (IsAuthorizedPermission(PermissionNames.Edit))
            {
                <div class="mt-2">
                <ActionLink Action="Edit" Parameters="@($"id={_dataRoom?.DataRoomId ?? 0}")" Text="@Localizer["Configure"]" Class="btn btn-sm btn-primary" />
                </div>
        }
    </div>
}
else if (!_dataRoom.IsActive)
{
    <div class="alert alert-warning mb-0">@Localizer["InactiveMessage"]</div>
    <ActionLink Action="Edit" Parameters="@($"id={_dataRoom?.DataRoomId ?? 0}")" Text="@Localizer["Configure"]" Class="btn btn-sm btn-primary mt-2" />
}
else if (!_isViewRoleAuthorized)
{
    <div class="alert alert-danger mb-0">@Localizer["NotAuthorizedMessage"]</div>
}
else
{
   
    <div class="dataroom">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h2 class="mb-0">@_dataRoom.Name</h2>
                @if (!string.IsNullOrEmpty(_dataRoom.Description))
                {
                    <h5 class="text-muted">@_dataRoom.Description</h5>
                }
            </div>
            <div class="d-flex gap-2">
                @if (_files != null && _files.Any() && (_dataRoom.EnableDownload))
                {
                    <button class="btn btn-sm btn-outline-secondary" @onclick="DownloadZipAsync"
                            title="Download all files as a ZIP archive">
                        <span class="oi oi-data-transfer-download me-1"></span>@Localizer["DownloadAllZip"]
                    </button>
                }

                @if (_dataRoom.EnableSubscription && PageState?.User != null)
                {
                    @if (_userSubscription != null && _userSubscription.SubscriptionId > 0)
                    {
                        <button class="btn btn-sm btn-outline-success" @onclick="UnsubscribeAsync" disabled="@_subscriptionBusy" title="@Localizer["UnsubscribeFromNotifications"]">
                            <span class="oi oi-bell me-1" style="color: green;"></span>@Localizer["Subscribed"]
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-outline-secondary" @onclick="OpenSubscribeDialogAsync" disabled="@_subscriptionBusy" title="@Localizer["SubscribeToNotifications"]">
                            <span class="oi oi-bell me-1"></span>@Localizer["Subscribe"]
                        </button>
                    }
                }



                @if (IsAuthorizedPermission(PermissionNames.Edit))
                {
                    <ActionLink Action="Edit" Parameters="@($"id={_dataRoom.DataRoomId}")" Class="btn btn-sm btn-outline-secondary" Text="@Localizer["Manage"]" />
                }
            </div>
        </div>

        <!-- Navigation Section - Always visible -->
        @if (CanNavigateUp)
        {
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <span class="text-muted small"><b>@Localizer["CurrentFolder"]</b> @_currentFolderPath</span>
                    @if (GetFileCount() > 0)
                    {
                        <span class="ms-2 text-muted small">
                            <b>@Localizer["Items"]</b> @GetFileCount()
                        </span>
                    }
                </div>
                <button class="btn btn-sm btn-outline-secondary" @onclick="OpenParentFolder">
                    <span class="oi oi-arrow-thick-left me-1"></span>@Localizer["UpOneLevel"]
                </button>
            </div>
        }

        @if (_browserItems != null && _browserItems.Any())
        {
            <Pager TableItem="FolderBrowserItem"
                   Items="@_browserItems"
                   Format="Table"
                   Toolbar="Bottom" 
                   PageSize="@_numberPerPage.ToString()" 
                   Class="table table-striped table-hover table-sm align-middle mb-0">        
                <Header>               
                    <th style="cursor: pointer;" @onclick='@(() => OnSortColumnChanged("Name"))'>
                        @Localizer["Name"]
                        @if (_sortColumn == "Name")
                        {
                            <span class="oi oi-sort-@(_sortDescending ? "descending" : "ascending")" style="margin-left: 5px;"></span>
                        }
                    </th>
                    <th style="cursor: pointer;" @onclick='@(() => OnSortColumnChanged("Type"))'>
                        @Localizer["Type"]
                        @if (_sortColumn == "Type")
                        {
                            <span class="oi oi-sort-@(_sortDescending ? "descending" : "ascending")" style="margin-left: 5px;"></span>
                        }
                    </th>
                    <th style="cursor: pointer;" @onclick='@(() => OnSortColumnChanged("Size"))'>
                        @Localizer["Size"]
                        @if (_sortColumn == "Size")
                        {
                            <span class="oi oi-sort-@(_sortDescending ? "descending" : "ascending")" style="margin-left: 5px;"></span>
                        }
                    </th>
                    <th style="cursor: pointer;" @onclick='@(() => OnSortColumnChanged("ModifiedOn"))'>
                        @Localizer["Modified"]
                        @if (_sortColumn == "ModifiedOn")
                        {
                            <span class="oi oi-sort-@(_sortDescending ? "descending" : "ascending")" style="margin-left: 5px;"></span>
                        }
                    </th>
                    <th class="text-end">@Localizer["Action"] </th>
                </Header>

                <Row Context="item">
                    @if (item.IsFolder)
                    {
                        <td>
                            <button class="btn btn-link btn-sm p-0 text-start" @onclick="() => OpenFolder(item.FolderId)">
                                <span class="oi oi-folder me-1"></span>@item.Name
                            </button>
                        </td>
                        <td><span class="badge bg-light text-dark border">@Localizer["Folder"]</span></td>
                        <td></td>
                        <td></td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => OpenFolder(item.FolderId)">@Localizer["Open"]</button>
                            <span class="badge bg-light text-dark border">@GetFileCount(item.FolderId) @Localizer["Files"]</span>
                        </td>
                    }
                    else
                    {
                        <td>@item.Name</td>
                        <td><span class="badge bg-light text-dark border">@item.Extension?.TrimStart('.').ToUpper()</span></td>
                        <td class="text-nowrap">@FormatSize(item.Size)</td>
                        <td class="text-nowrap">@UtcToLocal(item.ModifiedOn)?.ToString("g")</td>
                        <td class="text-end">
                            @{
                                var ext = item.Extension?.TrimStart('.').ToLower() ?? string.Empty;
                                var isOfficeDoc = new[] { "doc", "docx", "xls", "xlsx", "ppt", "pptx" }.Contains(ext);
                            }
                            @if (isOfficeDoc)
                            {
                                <img src="@GetFileTypeIcon(ext)" alt="@GetFileTypeLabel(ext)" style="height: 1.5rem; width: 1.5rem; margin-right: 0.5rem;" title="@GetFileTypeLabel(ext)" />
                                @if (_dataRoom.EnableDownload)
                                {
                                    <button class="btn btn-sm btn-primary"
                                            @onclick="@(async () => await DownloadFileAsync(item.FileId, item.Name))"
                                            title="Download @item.Name">
                                        <span class="oi oi-cloud-download me-1"></span>@Localizer["Download"]
                                    </button>
                                }
                            }
                            else
                            {
                                @if (_dataRoom.EnableViewOnly)
                                {
                                    <ActionLink Action="View" Parameters="@($"fileid={item.FileId}&dataroomid={_dataRoom.DataRoomId}")" IconName="eye" Text="@Localizer["View"]" Class="btn btn-sm btn-info text-white me-1">
                                    </ActionLink>
                                }
                                @if (_dataRoom.EnableDownload)
                                {
                                    <button class="btn btn-sm btn-primary"
                                            @onclick="@(async () => await DownloadFileAsync(item.FileId, item.Name))"
                                            title="Download @item.Name">
                                        <span class="oi oi-cloud-download me-1"></span>@Localizer["Download"]
                                    </button>
                                }
                                @if (!_dataRoom.EnableViewOnly && !_dataRoom.EnableDownload)
                                {
                                    <span class="text-muted small">@Localizer["AccessRestricted"]</span>
                                }
                            }
                        </td>
                    }
                </Row>
            </Pager>
        }
        else
        {
            <div class="text-center text-muted py-5">
                <div class="oi oi-inbox" style="font-size:2rem;"></div>
                <p class="mt-2 mb-0">@Localizer["NoDocumentsAvailable"]</p>
            </div>
        }
    </div>
}

<!-- Subscription Dialog Modal -->
@if (_showSubscribeDialog)
{
    <div class="modal fade show d-block" role="dialog" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@Localizer["SubscribeFolderNotifications"]</h5>
                    <button type="button" class="btn-close" @onclick="() => _showSubscribeDialog = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">@Localizer["Folder"]</label>
                        <div class="form-control" style="height: auto; padding: 0.75rem;">
                            <strong>@_currentFolderPath</strong>
                        </div>
                    </div>

                    @if (_currentFolderHasSubfolders)
                    {
                        <div class="mb-3 form-check">
                            <input type="checkbox" class="form-check-input" id="includeSubfolders" @bind="_includeSubfolders" />
                            <label class="form-check-label" for="includeSubfolders">
                                @Localizer["IncludeSubfolders"]
                            </label>
                            <small class="d-block text-muted mt-1">
                                @Localizer["IncludeSubfoldersHelp"]
                            </small>
                        </div>
                    }

                    <div class="mb-3">
                        <p class="text-muted small">@Localizer["NotifyOnUploadDescription"]</p>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => _showSubscribeDialog = false">
                        @Localizer["Cancel"]
                    </button>
                    <button type="button" class="btn btn-primary" @onclick="ConfirmSubscribeAsync" disabled="@_subscriptionBusy">
                        @Localizer["Subscribe"]
                    </button>
                </div>
            </div>
        </div>
    </div>
}

