    private string GetFileTypeIcon(string extension)
    {
        return extension switch
        {
            "doc" or "docx" => "/_content/GIBS.Module.DataRoom/icons/word.svg",
            "xls" or "xlsx" => "/_content/GIBS.Module.DataRoom/icons/excel.svg",
            "ppt" or "pptx" => "/_content/GIBS.Module.DataRoom/icons/powerpoint.svg",
            _ => "/_content/GIBS.Module.DataRoom/icons/word.svg"
        };
    }

    private string GetFileTypeLabel(string extension)
    {
        return extension switch
        {
            "doc" or "docx" => "Word Document",
            "xls" or "xlsx" => "Excel Spreadsheet",
            "ppt" or "pptx" => "PowerPoint Presentation",
            _ => "Document"
        };
    }

    private async Task SetLanguageAsync(string languageCode)
    {
        try
        {
            _currentLanguage = languageCode;

            // Build the cookie value: "c=it|uic=en" format
            string cookieValue = $"c={languageCode}|uic=en";

            // Update current UI culture field (used by GetLocalizedString)
            var cultureInfo = new System.Globalization.CultureInfo(
                languageCode == "it" ? "it-IT" : "en-US");
            System.Globalization.CultureInfo.CurrentUICulture = cultureInfo;
            _currentUICulture = cultureInfo; // Update our field so GetLocalizedString uses it

            // Trigger re-render immediately with new language
            StateHasChanged();

            // Set the cookie in background (fire and forget) for persistence on future loads
            _ = JSRuntime.InvokeVoidAsync("GIBS.DataRoom.setCultureCookie", cookieValue);
        }
        catch (Exception ex)
        {
            // Silent fail - language switch happened, cookie setting failed is not critical
        }
    }

    private async Task SubscribeAsync()
    {
        try
        {
            _subscriptionBusy = true;

            if (PageState?.User == null)
            {
                AddModuleMessage("Please log in to subscribe.", MessageType.Warning);
                return;
            }

            var subscription = new Subscription
            {
                DataRoomId = _dataRoom.DataRoomId,
                UserId = PageState.User.UserId,
                NotifyOnUpload = true,
                NotifyOnOverwrite = true,
                IsActive = true
            };

            _userSubscription = await SubscriptionService.AddSubscriptionAsync(subscription, ModuleState.ModuleId);
            _isSubscribed = _userSubscription?.SubscriptionId > 0;
            StateHasChanged();
            AddModuleMessage("Successfully subscribed to notifications.", MessageType.Success);
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error subscribing to notifications - {Error}", ex.Message);
            AddModuleMessage("Error subscribing to notifications.", MessageType.Error);
        }
        finally
        {
            _subscriptionBusy = false;
        }
    }

    private async Task UnsubscribeAsync()
    {
        try
        {
            _subscriptionBusy = true;

            if (_userSubscription?.SubscriptionId > 0)
            {
                await SubscriptionService.DeleteSubscriptionAsync(_userSubscription.SubscriptionId, ModuleState.ModuleId);
                _userSubscription = new Subscription();
                _isSubscribed = false;
                StateHasChanged();
                AddModuleMessage("Successfully unsubscribed from notifications.", MessageType.Success);
            }
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error unsubscribing from notifications - {Error}", ex.Message);
            AddModuleMessage("Error unsubscribing from notifications.", MessageType.Error);
        }
        finally
        {
            _subscriptionBusy = false;
        }
    }

    /// <summary>
    /// Gets a localized string, respecting the current culture from CultureInfo.CurrentUICulture.
    /// This is needed because IStringLocalizer caches based on the culture at component initialization,
    /// but we're setting the culture in OnAfterRenderAsync (after render).
    /// </summary>
    private string GetLocalizedString(string key)
    {
        try
        {
            // Use ResourceManager to load strings based on the current stored culture
            var assembly = typeof(GIBS.Module.DataRoom.Index).Assembly;
            var baseName = "GIBS.Module.DataRoom.Resources.GIBS.Module.DataRoom.Index";
            var rm = new System.Resources.ResourceManager(baseName, assembly);
            var localized = rm.GetString(key, _currentUICulture);
            return localized ?? key;
        }
        catch (Exception ex)
        {
            // If ResourceManager fails, fallback to the localizer
            var value = Localizer[key];
            return value.ResourceNotFound ? key : value;
        }
    }
