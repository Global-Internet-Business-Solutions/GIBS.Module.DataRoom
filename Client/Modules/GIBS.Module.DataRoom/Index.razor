    private async Task OpenSubscribeDialogAsync()
    {
        if (PageState?.User == null)
        {
            AddModuleMessage("Please log in to subscribe.", MessageType.Warning);
            return;
        }

        _currentFolderPath = GetCurrentFolderPath(_currentFolderId);
        _currentFolderHasSubfolders = HasSubfolders(_currentFolderId);
        _includeSubfolders = true;
        _showSubscribeDialog = true;
        StateHasChanged();
    }

    private async Task ConfirmSubscribeAsync()
    {
        _showSubscribeDialog = false;
        await SubscribeAsync(_currentFolderId, _includeSubfolders);
    }

    private async Task SubscribeAsync(int folderId, bool includeSubfolders)
    {
        try
        {
            _subscriptionBusy = true;

            if (PageState?.User == null)
            {
                AddModuleMessage("Please log in to subscribe.", MessageType.Warning);
                return;
            }

            var subscription = new Subscription
            {
                DataRoomId = _dataRoom.DataRoomId,
                UserId = PageState.User.UserId,
                NotifyOnUpload = true,
                NotifyOnOverwrite = true,
                IsActive = true,
                FolderId = folderId,
                IncludeSubfolders = includeSubfolders
            };

            _userSubscription = await SubscriptionService.AddSubscriptionAsync(subscription, ModuleState.ModuleId);
            _isSubscribed = _userSubscription?.SubscriptionId > 0;
            StateHasChanged();
            AddModuleMessage("Successfully subscribed to notifications.", MessageType.Success);
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error subscribing to notifications - {Error}", ex.Message);
            AddModuleMessage("Error subscribing to notifications.", MessageType.Error);
        }
        finally
        {
            _subscriptionBusy = false;
        }
    }

    private async Task UnsubscribeAsync()
    {
        try
        {
            _subscriptionBusy = true;

            if (_userSubscription?.SubscriptionId > 0)
            {
                await SubscriptionService.DeleteSubscriptionAsync(_userSubscription.SubscriptionId, ModuleState.ModuleId);
                _userSubscription = new Subscription();
                _isSubscribed = false;
                StateHasChanged();
                AddModuleMessage("Successfully unsubscribed from notifications.", MessageType.Success);
            }
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error unsubscribing from notifications - {Error}", ex.Message);
            AddModuleMessage("Error unsubscribing from notifications.", MessageType.Error);
        }
        finally
        {
            _subscriptionBusy = false;
        }
    }

