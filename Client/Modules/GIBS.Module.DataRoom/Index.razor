    private bool IsUserAuthorizedForViewRole(string viewRoleSetting)
    {
        if (IsAuthorizedRole(RoleNames.Admin) || IsAuthorizedRole(RoleNames.Host))
        {
            return true;
        }

        if (string.IsNullOrWhiteSpace(viewRoleSetting))
        {
            return true;
        }

        var roles = viewRoleSetting
            .Split(new[] { ',', ';' }, StringSplitOptions.RemoveEmptyEntries)
            .Select(r => r.Trim())
            .Where(r => !string.IsNullOrWhiteSpace(r));

        return roles.Any(IsAuthorizedRole);
    }

    private async Task NotifyUnauthorizedAccessAsync()
    {
        if (_dataRoom == null || string.IsNullOrWhiteSpace(_dataRoom.NotificationEmails) || PageState.User == null)
        {
            return;
        }

        var subject = $"Unauthorized Data Room Access Attempt: {_dataRoom.Name}";
        var body = $"User '{PageState.User.DisplayName}' ({PageState.User.Email}) attempted to access Data Room '{_dataRoom.Name}' on {DateTime.UtcNow:u}. Required role(s): {_ViewRole}.";

        var recipients = _dataRoom.NotificationEmails
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(e => e.Trim())
            .Where(e => !string.IsNullOrWhiteSpace(e))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        foreach (var email in recipients)
        {
            try
            {
                var notification = new Notification(ModuleState.SiteId, email, email, subject, body)
                {
                    FromUserId = PageState.User.UserId,
                    FromDisplayName = PageState.User.DisplayName,
                    FromEmail = PageState.User.Email ?? string.Empty
                };
                await NotificationService.AddNotificationAsync(notification);
            }
            catch (Exception ex)
            {
                await logger.LogError(ex, "Error sending unauthorized access notification to {Email} for DataRoom {DataRoomId}", email, _dataRoom.DataRoomId);
            }
        }
    }

    private async Task<List<Oqtane.Models.File>> GetFilesFromFolderHierarchyAsync(int rootFolderId, List<Folder> folders)
    {
        var childrenByParent = folders
            .Where(f => f.ParentId.HasValue)
            .GroupBy(f => f.ParentId.Value)
            .ToDictionary(g => g.Key, g => g.Select(f => f.FolderId).ToList());

        var folderIds = new HashSet<int> { rootFolderId };
        var queue = new Queue<int>();
        queue.Enqueue(rootFolderId);

        while (queue.Count > 0)
        {
            var currentFolderId = queue.Dequeue();
            if (!childrenByParent.TryGetValue(currentFolderId, out var childIds))
            {
                continue;
            }

            foreach (var childId in childIds)
            {
                if (folderIds.Add(childId))
                {
                    queue.Enqueue(childId);
                }
            }
        }

        _allowedFolderIds = folderIds;

        var files = new List<Oqtane.Models.File>();
        foreach (var folderId in folderIds)
        {
            var folderFiles = await FileService.GetFilesAsync(folderId) ?? new List<Oqtane.Models.File>();
            files.AddRange(folderFiles);
        }

        return files
            .OrderBy(f => f.Name)
            .ToList();
    }

    private bool CanNavigateUp =>
        _currentFolderId != _rootFolderId &&
        _folderLookup.TryGetValue(_currentFolderId, out var folder) &&
        folder.ParentId.HasValue &&
        _allowedFolderIds.Contains(folder.ParentId.Value);

    private void OpenFolder(int folderId)
    {
        if (!_allowedFolderIds.Contains(folderId))
        {
            return;
        }

        _currentFolderId = folderId;
        BuildBrowserItems();
    }

    private void OpenParentFolder()
    {
        if (!CanNavigateUp)
        {
            return;
        }

        var parentId = _folderLookup[_currentFolderId].ParentId.Value;
        _currentFolderId = parentId;
        BuildBrowserItems();
    }

    private void BuildBrowserItems()
    {
        var items = new List<FolderBrowserItem>();

        var childFolders = _folders
            .Where(f => f.ParentId == _currentFolderId && _allowedFolderIds.Contains(f.FolderId))
            .OrderBy(f => f.Name)
            .Select(f => new FolderBrowserItem
            {
                IsFolder = true,
                FolderId = f.FolderId,
                Name = f.Name
            });

        items.AddRange(childFolders);

        var currentFolderFiles = (_files ?? new List<Oqtane.Models.File>())
            .Where(f => f.FolderId == _currentFolderId)
            .Select(f => new FolderBrowserItem
            {
                IsFolder = false,
                FolderId = f.FolderId,
                FileId = f.FileId,
                Name = f.Name,
                Extension = f.Extension,
                Size = f.Size,
                ModifiedOn = f.ModifiedOn
            })
            .ToList();

        // Apply sorting based on _sortColumn and _sortDescending
        currentFolderFiles = ApplySorting(currentFolderFiles);
        items.AddRange(currentFolderFiles);

        _browserItems = items;
        _currentFolderPath = GetCurrentFolderPath(_currentFolderId);
    }

    private string GetCurrentFolderPath(int folderId)
    {
        if (!_folderLookup.ContainsKey(folderId))
        {
            return "Unknown";
        }

        var segments = new Stack<string>();
        var visited = new HashSet<int>();
        var currentId = folderId;

        while (_folderLookup.TryGetValue(currentId, out var folder) && visited.Add(currentId))
        {
            segments.Push(folder.Name);

            if (!folder.ParentId.HasValue)
            {
                break;
            }

            currentId = folder.ParentId.Value;
        }

        return string.Join("/", segments);
    }

    private bool HasSubfolders(int folderId)
    {
        return _folders.Any(f => f.ParentId == folderId && _allowedFolderIds.Contains(f.FolderId));
    }

    private List<FolderBrowserItem> ApplySorting(List<FolderBrowserItem> items)
    {
        return _sortColumn switch
        {
            "Name" => _sortDescending 
                ? items.OrderByDescending(x => x.Name).ToList()
                : items.OrderBy(x => x.Name).ToList(),
            "Type" => _sortDescending
                ? items.OrderByDescending(x => x.Extension ?? "").ToList()
                : items.OrderBy(x => x.Extension ?? "").ToList(),
            "Size" => _sortDescending
                ? items.OrderByDescending(x => x.Size).ToList()
                : items.OrderBy(x => x.Size).ToList(),
            "ModifiedOn" => _sortDescending
                ? items.OrderByDescending(x => x.ModifiedOn).ToList()
                : items.OrderBy(x => x.ModifiedOn).ToList(),
            _ => _sortDescending
                ? items.OrderByDescending(x => x.ModifiedOn).ToList()
                : items.OrderBy(x => x.ModifiedOn).ToList()
        };
    }

    private void OnSortColumnChanged(string columnName)
    {
        if (_sortColumn == columnName)
        {
            // If clicking the same column, toggle the sort direction
            _sortDescending = !_sortDescending;
        }
        else
        {
            // If clicking a different column, set it as the new sort column with descending order
            _sortColumn = columnName;
            _sortDescending = true;
        }

        BuildBrowserItems();
    }

