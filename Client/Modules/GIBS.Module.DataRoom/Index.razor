@using GIBS.Module.DataRoom.Services
@using GIBS.Module.DataRoom.Models
@using Oqtane.Models

@namespace GIBS.Module.DataRoom
@inherits ModuleBase
@inject IDataRoomService DataRoomService
@inject IDataRoomActivityLogService ActivityLogService
@inject IFolderService FolderService
@inject IFileService FileService
@inject ISettingService SettingService
@inject INotificationService NotificationService

@if (!_initialized)
{
    <div class="text-center py-3">
        <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
    </div>
}
else if (_dataRoom == null)
{
    <div class="alert alert-info">
        <p class="mb-0">You may not have permissions to access this data room. Please contact the site administrator.</p>
        @if (IsAuthorizedPermission(PermissionNames.Edit))
        {
            <div class="mt-2">
                <ActionLink Action="Edit" Parameters="@($"id={_dataRoom?.DataRoomId ?? 0}")" Text="Configure Data Room" Class="btn btn-sm btn-primary" />
            </div>
        }
    </div>
}
else if (!_dataRoom.IsActive)
{
    <div class="alert alert-warning mb-0">This Data Room is currently inactive.</div>
}
else if (!_isViewRoleAuthorized)
{
    <div class="alert alert-danger mb-0">You are not authorized to view this Data Room. Are you logged in?</div>
}
else
{
    <div class="dataroom">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h2 class="mb-0">@_dataRoom.Name</h2>
                @if (!string.IsNullOrEmpty(_dataRoom.Description))
                {
                    <h5 class="text-muted">@_dataRoom.Description</h5>
                }
            </div>
            <div class="d-flex gap-2">
                @if (_files != null && _files.Any() && (_dataRoom.EnableDownload))
                {
                    <button class="btn btn-sm btn-outline-secondary" @onclick="DownloadZipAsync"
                            title="Download all files as a ZIP archive">
                        <span class="oi oi-data-transfer-download me-1"></span>Download All (ZIP)
                    </button>
                }
                @if (IsAuthorizedPermission(PermissionNames.Edit))
                {
                    <ActionLink Action="Edit" Parameters="@($"id={_dataRoom.DataRoomId}")" Class="btn btn-sm btn-outline-secondary" Text="Manage" />
                }
            </div>
        </div>

        <!-- Navigation Section - Always visible -->
        @if (CanNavigateUp)
        {
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <span class="text-muted small"><b>Current Folder:</b> @_currentFolderPath</span>
                    @if (_browserItems != null && _browserItems.Any())
                    {
                        <span class="ms-2 text-muted small">
                            <b>Items:</b> @_browserItems.Count
                        </span>
                    }
                </div>
                <button class="btn btn-sm btn-outline-secondary" @onclick="OpenParentFolder">
                    <span class="oi oi-arrow-thick-left me-1"></span>Up One Level
                </button>
            </div>
        }

        @if (_browserItems != null && _browserItems.Any())
        {
            <Pager TableItem="FolderBrowserItem"
                   Items="@_browserItems"
                   Format="Table"
                   Toolbar="Bottom" 
                   PageSize="@_numberPerPage.ToString()" 
                   Class="table table-striped table-hover table-sm align-middle mb-0">        
                <Header>               
                    <th style="cursor: pointer;" @onclick='@(() => OnSortColumnChanged("Name"))'>
                        Name
                        @if (_sortColumn == "Name")
                        {
                            <span class="oi oi-sort-@(_sortDescending ? "descending" : "ascending")" style="margin-left: 5px;"></span>
                        }
                    </th>
                    <th style="cursor: pointer;" @onclick='@(() => OnSortColumnChanged("Type"))'>
                        Type
                        @if (_sortColumn == "Type")
                        {
                            <span class="oi oi-sort-@(_sortDescending ? "descending" : "ascending")" style="margin-left: 5px;"></span>
                        }
                    </th>
                    <th style="cursor: pointer;" @onclick='@(() => OnSortColumnChanged("Size"))'>
                        Size
                        @if (_sortColumn == "Size")
                        {
                            <span class="oi oi-sort-@(_sortDescending ? "descending" : "ascending")" style="margin-left: 5px;"></span>
                        }
                    </th>
                    <th style="cursor: pointer;" @onclick='@(() => OnSortColumnChanged("ModifiedOn"))'>
                        Modified
                        @if (_sortColumn == "ModifiedOn")
                        {
                            <span class="oi oi-sort-@(_sortDescending ? "descending" : "ascending")" style="margin-left: 5px;"></span>
                        }
                    </th>
                    <th class="text-end">Action</th>          
                </Header>

                <Row Context="item">
                    @if (item.IsFolder)
                    {
                        <td>
                            <button class="btn btn-link btn-sm p-0 text-start" @onclick="() => OpenFolder(item.FolderId)">
                                <span class="oi oi-folder me-1"></span>@item.Name
                            </button>
                        </td>
                        <td><span class="badge bg-light text-dark border">Folder</span></td>
                        <td></td>
                        <td></td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => OpenFolder(item.FolderId)">Open</button>
                        </td>
                    }
                    else
                    {
                        <td>@item.Name</td>
                        <td><span class="badge bg-light text-dark border">@item.Extension?.TrimStart('.').ToUpper()</span></td>
                        <td class="text-nowrap">@FormatSize(item.Size)</td>
                        <td class="text-nowrap">@UtcToLocal(item.ModifiedOn)?.ToString("g")</td>
                        <td class="text-end">
                            @{
                                var ext = item.Extension?.TrimStart('.').ToLower() ?? string.Empty;
                                var isOfficeDoc = new[] { "doc", "docx", "xls", "xlsx", "ppt", "pptx" }.Contains(ext);
                            }
                            @if (isOfficeDoc)
                            {
                                <img src="@GetFileTypeIcon(ext)" alt="@GetFileTypeLabel(ext)" style="height: 1.5rem; width: 1.5rem; margin-right: 0.5rem;" title="@GetFileTypeLabel(ext)" />
                                @if (_dataRoom.EnableDownload)
                                {
                                    <button class="btn btn-sm btn-primary"
                                            @onclick="@(async () => await DownloadFileAsync(item.FileId, item.Name))"
                                            title="Download @item.Name">
                                        <span class="oi oi-cloud-download me-1"></span>Download
                                    </button>
                                }
                            }
                            else
                            {
                                @if (_dataRoom.EnableViewOnly)
                                {
                                    <ActionLink Action="View" Parameters="@($"fileid={item.FileId}&dataroomid={_dataRoom.DataRoomId}")" IconName="eye" Text="View" Class="btn btn-sm btn-info text-white me-1">
                                    </ActionLink>
                                }
                                @if (_dataRoom.EnableDownload)
                                {
                                    <button class="btn btn-sm btn-primary"
                                            @onclick="@(async () => await DownloadFileAsync(item.FileId, item.Name))"
                                            title="Download @item.Name">
                                        <span class="oi oi-cloud-download me-1"></span>Download
                                    </button>
                                }
                                @if (!_dataRoom.EnableViewOnly && !_dataRoom.EnableDownload)
                                {
                                    <span class="text-muted small">Access Restricted</span>
                                }
                            }
                        </td>
                    }
                </Row>
            </Pager>
        }
        else
        {
            <div class="text-center text-muted py-5">
                <div class="oi oi-inbox" style="font-size:2rem;"></div>
                <p class="mt-2 mb-0">No documents available in this folder.</p>
            </div>
        }
    </div>
}

@code {
    public override List<Resource> Resources => new List<Resource>
    {
        new Stylesheet("_content/GIBS.Module.DataRoom/Module.css")
    };

    private bool _initialized;
    private DataRoom _dataRoom;
    private List<Oqtane.Models.File> _files;
    private List<Folder> _folders = new();
    private List<FolderBrowserItem> _browserItems = new();
    private Dictionary<int, Folder> _folderLookup = new();
    private HashSet<int> _allowedFolderIds = new();
    private int _rootFolderId;
    private int _currentFolderId;
    private string _currentFolderPath = string.Empty;
    private string _ViewRole;
    private int _numberPerPage = 10;
    private bool _isViewRoleAuthorized = true;
    private string _sortColumn = "ModifiedOn";
    private bool _sortDescending = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var settings = await SettingService.GetModuleSettingsAsync(ModuleState.ModuleId);
            _ViewRole = SettingService.GetSetting(settings, "ViewRole", "");

            var numberPerPageSetting = SettingService.GetSetting(settings, "NumberPerPage", "10");
            if (!int.TryParse(numberPerPageSetting, out _numberPerPage) || _numberPerPage < 1)
            {
                _numberPerPage = 10;
            }

            _isViewRoleAuthorized = IsUserAuthorizedForViewRole(_ViewRole);
            if (!_isViewRoleAuthorized)
            {
                await NotifyUnauthorizedAccessAsync();
                _initialized = true;
                return;
            }

            var rooms = await DataRoomService.GetDataRoomsAsync(ModuleState.ModuleId);
            _dataRoom = rooms?.FirstOrDefault(r => r.IsActive) ?? rooms?.FirstOrDefault();

            // if (_dataRoom != null)
            // {
            //     _isViewRoleAuthorized = IsUserAuthorizedForViewRole(_ViewRole);
            //     if (!_isViewRoleAuthorized)
            //     {
            //         await NotifyUnauthorizedAccessAsync();
            //         _initialized = true;
            //         return;
            //     }
            // }

            if (_dataRoom != null && _dataRoom.IsActive && _dataRoom.FolderId > 0)
            {
                try
                {
                    _folders = await FolderService.GetFoldersAsync(ModuleState.SiteId) ?? new List<Folder>();
                    _folderLookup = _folders.ToDictionary(f => f.FolderId);
                    _files = await GetFilesFromFolderHierarchyAsync(_dataRoom.FolderId, _folders);

                    _rootFolderId = _dataRoom.FolderId;
                    _currentFolderId = _rootFolderId;
                    BuildBrowserItems();
                }
                catch (Exception ex)
                {
                    await logger.LogError(ex, "Error Loading File List for Data Room (FolderId: {FolderId}) - {Error}", _dataRoom.FolderId, ex.Message);
                    _files = new List<Oqtane.Models.File>();
                    _browserItems = new List<FolderBrowserItem>();
                    AddModuleMessage("Insufficient permissions to view the contents of this folder. Please contact an administrator.", MessageType.Warning);
                }

                if (PageState.User != null)
                {
                    await ActivityLogService.AddActivityLogAsync(new DataRoomActivityLog
                    {
                        DataRoomId = _dataRoom.DataRoomId, 
                        FileId = 0,
                        UserId = PageState.User.UserId.ToString(),
                        Action = "ViewList",
                        Timestamp = DateTime.UtcNow,
                        IPAddress = string.Empty
                    }, ModuleState.ModuleId);
                }
            }

            _initialized = true;
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error Loading Data Room {Error}", ex.Message);
            AddModuleMessage("Error loading Data Room.", MessageType.Error);
        }
    }

    private bool IsUserAuthorizedForViewRole(string viewRoleSetting)
    {
        if (IsAuthorizedRole(RoleNames.Admin) || IsAuthorizedRole(RoleNames.Host))
        {
            return true;
        }

        if (string.IsNullOrWhiteSpace(viewRoleSetting))
        {
            return true;
        }

        var roles = viewRoleSetting
            .Split(new[] { ',', ';' }, StringSplitOptions.RemoveEmptyEntries)
            .Select(r => r.Trim())
            .Where(r => !string.IsNullOrWhiteSpace(r));

        return roles.Any(IsAuthorizedRole);
    }

    private async Task NotifyUnauthorizedAccessAsync()
    {
        if (_dataRoom == null || string.IsNullOrWhiteSpace(_dataRoom.NotificationEmails) || PageState.User == null)
        {
            return;
        }

        var subject = $"Unauthorized Data Room Access Attempt: {_dataRoom.Name}";
        var body = $"User '{PageState.User.DisplayName}' ({PageState.User.Email}) attempted to access Data Room '{_dataRoom.Name}' on {DateTime.UtcNow:u}. Required role(s): {_ViewRole}.";

        var recipients = _dataRoom.NotificationEmails
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(e => e.Trim())
            .Where(e => !string.IsNullOrWhiteSpace(e))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        foreach (var email in recipients)
        {
            try
            {
                var notification = new Notification(ModuleState.SiteId, email, email, subject, body)
                {
                    FromUserId = PageState.User.UserId,
                    FromDisplayName = PageState.User.DisplayName,
                    FromEmail = PageState.User.Email ?? string.Empty
                };
                await NotificationService.AddNotificationAsync(notification);
            }
            catch (Exception ex)
            {
                await logger.LogError(ex, "Error sending unauthorized access notification to {Email} for DataRoom {DataRoomId}", email, _dataRoom.DataRoomId);
            }
        }
    }

    private async Task<List<Oqtane.Models.File>> GetFilesFromFolderHierarchyAsync(int rootFolderId, List<Folder> folders)
    {
        var childrenByParent = folders
            .Where(f => f.ParentId.HasValue)
            .GroupBy(f => f.ParentId.Value)
            .ToDictionary(g => g.Key, g => g.Select(f => f.FolderId).ToList());

        var folderIds = new HashSet<int> { rootFolderId };
        var queue = new Queue<int>();
        queue.Enqueue(rootFolderId);

        while (queue.Count > 0)
        {
            var currentFolderId = queue.Dequeue();
            if (!childrenByParent.TryGetValue(currentFolderId, out var childIds))
            {
                continue;
            }

            foreach (var childId in childIds)
            {
                if (folderIds.Add(childId))
                {
                    queue.Enqueue(childId);
                }
            }
        }

        _allowedFolderIds = folderIds;

        var files = new List<Oqtane.Models.File>();
        foreach (var folderId in folderIds)
        {
            var folderFiles = await FileService.GetFilesAsync(folderId) ?? new List<Oqtane.Models.File>();
            files.AddRange(folderFiles);
        }

        return files
            .OrderBy(f => f.Name)
            .ToList();
    }

    private bool CanNavigateUp =>
        _currentFolderId != _rootFolderId &&
        _folderLookup.TryGetValue(_currentFolderId, out var folder) &&
        folder.ParentId.HasValue &&
        _allowedFolderIds.Contains(folder.ParentId.Value);

    private void OpenFolder(int folderId)
    {
        if (!_allowedFolderIds.Contains(folderId))
        {
            return;
        }

        _currentFolderId = folderId;
        BuildBrowserItems();
    }

    private void OpenParentFolder()
    {
        if (!CanNavigateUp)
        {
            return;
        }

        var parentId = _folderLookup[_currentFolderId].ParentId.Value;
        _currentFolderId = parentId;
        BuildBrowserItems();
    }

    private void BuildBrowserItems()
    {
        var items = new List<FolderBrowserItem>();

        var childFolders = _folders
            .Where(f => f.ParentId == _currentFolderId && _allowedFolderIds.Contains(f.FolderId))
            .OrderBy(f => f.Name)
            .Select(f => new FolderBrowserItem
            {
                IsFolder = true,
                FolderId = f.FolderId,
                Name = f.Name
            });

        items.AddRange(childFolders);

        var currentFolderFiles = (_files ?? new List<Oqtane.Models.File>())
            .Where(f => f.FolderId == _currentFolderId)
            .Select(f => new FolderBrowserItem
            {
                IsFolder = false,
                FolderId = f.FolderId,
                FileId = f.FileId,
                Name = f.Name,
                Extension = f.Extension,
                Size = f.Size,
                ModifiedOn = f.ModifiedOn
            })
            .ToList();

        // Apply sorting based on _sortColumn and _sortDescending
        currentFolderFiles = ApplySorting(currentFolderFiles);
        items.AddRange(currentFolderFiles);

        _browserItems = items;

        if (_folderLookup.TryGetValue(_currentFolderId, out var folder))
        {
            _currentFolderPath = folder.Path;
        }
        else
        {
            _currentFolderPath = "Unknown";
        }
    }

    private List<FolderBrowserItem> ApplySorting(List<FolderBrowserItem> items)
    {
        return _sortColumn switch
        {
            "Name" => _sortDescending 
                ? items.OrderByDescending(x => x.Name).ToList()
                : items.OrderBy(x => x.Name).ToList(),
            "Type" => _sortDescending
                ? items.OrderByDescending(x => x.Extension ?? "").ToList()
                : items.OrderBy(x => x.Extension ?? "").ToList(),
            "Size" => _sortDescending
                ? items.OrderByDescending(x => x.Size).ToList()
                : items.OrderBy(x => x.Size).ToList(),
            "ModifiedOn" => _sortDescending
                ? items.OrderByDescending(x => x.ModifiedOn).ToList()
                : items.OrderBy(x => x.ModifiedOn).ToList(),
            _ => _sortDescending
                ? items.OrderByDescending(x => x.ModifiedOn).ToList()
                : items.OrderBy(x => x.ModifiedOn).ToList()
        };
    }

    private void OnSortColumnChanged(string columnName)
    {
        if (_sortColumn == columnName)
        {
            // If clicking the same column, toggle the sort direction
            _sortDescending = !_sortDescending;
        }
        else
        {
            // If clicking a different column, set it as the new sort column with descending order
            _sortColumn = columnName;
            _sortDescending = true;
        }

        BuildBrowserItems();
    }

    private class FolderBrowserItem
    {
        public bool IsFolder { get; set; }
        public int FolderId { get; set; }
        public int FileId { get; set; }
        public string Name { get; set; }
        public string Extension { get; set; }
        public int Size { get; set; }
        public DateTime ModifiedOn { get; set; }
    }

    private async Task DownloadFileAsync(int fileId, string fileName)
    {
        try
        {
            if (_dataRoom == null) return;

            if (PageState.User != null)
            {
                await ActivityLogService.AddActivityLogAsync(new DataRoomActivityLog
                {
                    DataRoomId = _dataRoom.DataRoomId,
                    FileId = fileId,
                    UserId = PageState.User.UserId.ToString(),
                    Action = "Download",
                    Timestamp = DateTime.UtcNow,
                    IPAddress = string.Empty
                }, ModuleState.ModuleId);
            }

            // Open in new tab so the user stays on the Data Room page
            await JSRuntime.InvokeVoidAsync("open", FileUrl(fileId, true), "_blank");
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error Downloading File {FileId} {Error}", fileId, ex.Message);
            AddModuleMessage("Error downloading file.", MessageType.Error);
        }
    }

    private static string FormatSize(int bytes)
    {
        if (bytes < 1_024) return $"{bytes} B";
        if (bytes < 1_048_576) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / 1_048_576.0:F1} MB";
    }

    private async Task DownloadZipAsync()
    {
        var url = $"{PageState.Alias.BaseUrl}api/DataRoom/zip/{_dataRoom.DataRoomId}/{ModuleState.ModuleId}?authmoduleid={ModuleState.ModuleId}";
        await JSRuntime.InvokeVoidAsync("open", url, "_blank");
    }

    private string GetFileTypeIcon(string extension)
    {
        return extension switch
        {
            "doc" or "docx" => "/_content/GIBS.Module.DataRoom/icons/word.svg",
            "xls" or "xlsx" => "/_content/GIBS.Module.DataRoom/icons/excel.svg",
            "ppt" or "pptx" => "/_content/GIBS.Module.DataRoom/icons/powerpoint.svg",
            _ => "/_content/GIBS.Module.DataRoom/icons/word.svg"
        };
    }

    private string GetFileTypeLabel(string extension)
    {
        return extension switch
        {
            "doc" or "docx" => "Word Document",
            "xls" or "xlsx" => "Excel Spreadsheet",
            "ppt" or "pptx" => "PowerPoint Presentation",
            _ => "Document"
        };
    }
}