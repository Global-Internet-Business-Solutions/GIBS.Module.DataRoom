@using Oqtane.Modules.Controls
@using Oqtane.Models
@using GIBS.Module.DataRoom.Services
@using GIBS.Module.DataRoom.Models

@namespace GIBS.Module.DataRoom
@inherits ModuleBase
@inject IDataRoomService DataRoomService
@inject IDataRoomActivityLogService ActivityLogService
@inject IFolderService FolderService
@inject IFileService FileService
@inject IUserService UserService
@inject ISettingService SettingService
@inject NavigationManager NavigationManager
@inject HttpClient HttpClient

<TabStrip ActiveTab="@_activeTab">
       <TabPanel Name="Documents" Heading="Documents" ResourceKey="Documents">

           
            @if (_dataRoom != null && _dataRoom.FolderId > 0)
            {
            <FileManager FolderId="@_currentFolderId"
                         ShowFolders="true" ShowFiles="true"
                             UploadMultiple="true"
                             ShowSuccess="true"
                             OnUpload="HandleUploadAsync" />
                <hr />

                <div class="d-flex justify-content-between align-items-center my-3">
                    <div class="form-check form-switch">
                        <input type="checkbox" class="form-check-input" id="enableZipExtraction" @bind="_enableZipExtraction" style="width: 3rem; height: 1.5rem; cursor: pointer;" />
                        <label class="form-check-label" for="enableZipExtraction" style="cursor: pointer;">
                            Enable Zip Extraction
                        </label>
                    </div>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="DownloadZipAsync">
                        <span class="oi oi-data-transfer-download me-1"></span>Download All (ZIP)
                    </button>
                </div>

                <hr />

                @if (_browserItems != null && _browserItems.Any())
                {
            <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="text-muted small"><b>Current Folder:</b> @_currentFolderPath</span>
                @if (_currentFolderId != _rootFolderId)
                {
                    <button class="btn btn-sm btn-outline-secondary" @onclick="OpenParentFolder">
                        <span class="oi oi-arrow-thick-left me-1"></span>Up One Level
                    </button>
                }
            </div>
                    <Pager TableItem="FolderBrowserItem"
                           Items="@_browserItems"
                           Format="Table"
                           Toolbar="Bottom"
                           PageSize="@_numberPerPage.ToString()"
                           Class="table table-striped table-hover table-sm align-middle mb-0">
                        <Header>
                            <th style="cursor: pointer;" @onclick="@(() => OnSortColumnChanged("Name"))">
                                Name
                                @if (_sortColumn == "Name")
                                {
                                    <span class="oi oi-sort-@(_sortDescending ? "descending" : "ascending")" style="margin-left: 5px;"></span>
                                }
                            </th>
                            <th style="cursor: pointer;" @onclick="@(() => OnSortColumnChanged("Type"))">
                                Type
                                @if (_sortColumn == "Type")
                                {
                                    <span class="oi oi-sort-@(_sortDescending ? "descending" : "ascending")" style="margin-left: 5px;"></span>
                                }
                            </th>
                            <th style="cursor: pointer;" @onclick="@(() => OnSortColumnChanged("Size"))">
                                Size
                                @if (_sortColumn == "Size")
                                {
                                    <span class="oi oi-sort-@(_sortDescending ? "descending" : "ascending")" style="margin-left: 5px;"></span>
                                }
                            </th>
                            <th style="cursor: pointer;" @onclick="@(() => OnSortColumnChanged("ModifiedOn"))">
                                Modified
                                @if (_sortColumn == "ModifiedOn")
                                {
                                    <span class="oi oi-sort-@(_sortDescending ? "descending" : "ascending")" style="margin-left: 5px;"></span>
                                }
                            </th>
                            <th class="text-end">Action</th>
                        </Header>

                        <Row Context="item">
                            @if (item.IsFolder)
                            {
                                <td>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => OpenRenameFileDialog(item.FolderId, item.Name, false)"><i class="oi oi-pencil"></i></button>
                                    <button class="btn btn-link btn-sm p-0 text-start" @onclick="() => OpenFolder(item.FolderId)">
                                        <span class="oi oi-folder me-1"></span>@item.Name
                                    </button>
                                </td>
                                <td><span class="badge bg-light text-dark border">Folder</span></td>
                                <td></td>
                                <td></td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => OpenFolder(item.FolderId)">Open</button>
                                </td>
                            }
                            else
                            {
                                <td>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => OpenRenameFileDialog(item.FileId, item.Name, true)"><i class="oi oi-pencil"></i></button>
                                @item.Name</td>
                                <td><span class="badge bg-light text-dark border">@item.Extension?.TrimStart('.').ToUpper()</span></td>
                                <td class="text-nowrap">@FormatSize(item.Size)</td>
                                <td class="text-nowrap">@UtcToLocal(item.ModifiedOn)?.ToString("g")</td>
                                <td class="text-end">
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteFile(item.FileId)"><i class="oi oi-trash"></i></button>
                                </td>
                            }
                        </Row>
                    </Pager>
                }
                else
                {
                    <div class="alert alert-info">No files or folders found.</div>
                }



            }
            else
            {
                <div class="alert alert-info">Save the room settings and select a folder first.</div>
            }
        </TabPanel>

        <TabPanel Name="ActivityLog" Heading="Activity Log" ResourceKey="ActivityLog">
            @if (_activityLogs != null && _activityLogs.Any())
            {
                <Pager Items="@_activityLogs" SearchProperties="UserId">
                    <Header>
                        <th>Action</th>
                        <th>User ID</th>
                        <th>DisplayName</th>
                        <th>File</th>
                        <th>Timestamp</th>
                        <th>IP Address</th>
                    </Header>
                    <Row>
                        <td><span class="badge @GetActionBadge(context.Action)">@context.Action</span></td>
                        <td>@(string.IsNullOrEmpty(context.UserId) ? "-" : context.UserId)</td>
                        <td>@GetUserDisplay(context.UserId)</td>
                        <td>@GetFileName(context.FileId)</td>
                        <td>@UtcToLocal(context.Timestamp)?.ToString("g")</td>
                        <td>
                            @if (string.IsNullOrEmpty(context.IPAddress))
                            {
                                <span>-</span>
                            }
                            else
                            {
                                <a href="https://ip-address-lookup-v4.com/ip/@context.IPAddress" target="_blank">@context.IPAddress</a>
                            }
                        </td>
                    </Row>
                </Pager>
            }
            else
            {
                <div class="text-center text-muted py-3">No activity recorded yet.</div>
            }
        </TabPanel>
    

    <TabPanel Name="Settings" Heading="Room Settings" ResourceKey="Settings">
        @if (_folders != null)
        {
            <div class="container-fluid px-0">
                <div class="row mb-3 align-items-center">
                    <Label Class="col-sm-3" For="name" HelpText="The display name of this Data Room" ResourceKey="Name">Name:</Label>
                    <div class="col-sm-9">
                        <input id="name" class="form-control" @bind="_name" maxlength="200" />
                    </div>
                </div>
                <div class="row mb-3 align-items-center">
                    <Label Class="col-sm-3" For="description" HelpText="Optional description shown to users" ResourceKey="Description">Description:</Label>
                    <div class="col-sm-9">
                        <textarea id="description" class="form-control" @bind="_description" rows="3" maxlength="2000"></textarea>
                    </div>
                </div>
                <div class="row mb-3 align-items-center">
                    <Label Class="col-sm-3" For="folder" HelpText="The Oqtane folder that holds documents for this room" ResourceKey="Folder">Folder:</Label>
                    <div class="col-sm-9">
                        <select id="folder" class="form-select" @bind="_folderId">
                            <option value="0">&lt;Select a Folder&gt;</option>
                            @foreach (var folder in _folders)
                            {
                                <option value="@folder.FolderId">@(new string('\u00A0', folder.Level * 4))@folder.Name</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="row mb-3 align-items-center">
                    <Label Class="col-sm-3" For="active" HelpText="Controls whether users can access this Data Room" ResourceKey="IsActive">Active:</Label>
                    <div class="col-sm-9">
                        <div class="form-check form-switch">
                            <input id="active" class="form-check-input" type="checkbox" @bind="_isActive" />
                        </div>
                    </div>
                </div>
                <div class="row mb-3 align-items-center">
                    <Label Class="col-sm-3" For="emails" HelpText="Comma-separated email addresses notified when a document is uploaded" ResourceKey="NotificationEmails">Notify on Upload:</Label>
                    <div class="col-sm-9">
                        <input id="emails" class="form-control" @bind="_notificationEmails"
                               placeholder="alice@example.com, bob@example.com" />
                    </div>
                </div>
                <div class="row mb-3 align-items-center">
                    <Label Class="col-sm-3" For="enableDownload" HelpText="Controls whether users can download files directly" ResourceKey="EnableDownload">Enable Download:</Label>
                    <div class="col-sm-9">
                        <div class="form-check form-switch">
                            <input id="enableDownload" class="form-check-input" type="checkbox" @bind="_enableDownload" />
                        </div>
                    </div>
                </div>
                <div class="row mb-3 align-items-center">
                    <Label Class="col-sm-3" For="enableViewOnly" HelpText="Controls whether users can view files in the secure document viewer" ResourceKey="EnableViewOnly">Enable View Only:</Label>
                    <div class="col-sm-9">
                        <div class="form-check form-switch">
                            <input id="enableViewOnly" class="form-check-input" type="checkbox" @bind="_enableViewOnly" />
                        </div>
                    </div>
                </div>
                <div class="row mb-3 align-items-center">
                    <Label Class="col-sm-3" For="enableWatermark" HelpText="Applies dynamically generated watermarks for users when viewing PDFs" ResourceKey="EnableWatermark">Enable Watermark:</Label>
                    <div class="col-sm-9">
                        <div class="form-check form-switch">
                            <input id="enableWatermark" class="form-check-input" type="checkbox" @bind="_enableWatermark" />
                        </div>
                    </div>
                </div>
            </div>

            <button class="btn btn-success" @onclick="SaveAsync">Save</button>
            <NavLink class="btn btn-secondary ms-2" href="@NavigateUrl()">Cancel</NavLink>
            @if (_dataRoom != null)
            {
                <ActionDialog Header="Delete Data Room"
                              Message="@($"Are you sure you want to permanently delete '{_dataRoom.Name}'? This will not delete any files.")"
                              Action="Delete"
                              Security="SecurityAccessLevel.Edit"
                              Class="btn btn-danger ms-2"
                              OnClick="@(async () => await DeleteAsync())"
                              ResourceKey="Delete" />
                <br /><br />
                <AuditInfo CreatedBy="@_dataRoom.CreatedBy" CreatedOn="@_dataRoom.CreatedOn"
                           ModifiedBy="@_dataRoom.ModifiedBy" ModifiedOn="@_dataRoom.ModifiedOn" />
            }
        }
    </TabPanel>

    
</TabStrip>

@if (_showRenameFileDialog)
{
    <div class="modal d-block" style="display: block; background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Rename Item</h5>
                    <button type="button" class="btn-close" @onclick="() => _showRenameFileDialog = false"></button>
                </div>
                <div class="modal-body">
                    <div class="form-group mb-3">
                        <label for="renameInput">New Name:</label>
                        <input type="text" class="form-control" id="renameInput" @bind="_renameItemName" maxlength="255" />
                        @if (!string.IsNullOrEmpty(_renameFileExtension))
                        {
                            <div class="text-muted small mt-2">Extension: <strong>@_renameFileExtension</strong> (cannot be changed)</div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => _showRenameFileDialog = false">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="RenameItemAsync">Rename</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    public override SecurityAccessLevel SecurityAccessLevel => SecurityAccessLevel.Edit;
    public override bool UseAdminContainer => false;

    public override string Actions => "Add,Edit";

    public override string Title => _dataRoom == null ? "Add Data Room" : "Edit Data Room";

    public override List<Resource> Resources => new List<Resource>
    {
        new Stylesheet("_content/GIBS.Module.DataRoom/Module.css")
    };

    private DataRoom _dataRoom;
    private List<Folder> _folders;
    private List<DataRoomActivityLog> _activityLogs;
    private Dictionary<int, string> _fileNames = new();
    private Dictionary<string, string> _userDisplayNames = new(StringComparer.OrdinalIgnoreCase);

    private string _name = string.Empty;
    private string _description = string.Empty;
    private int _folderId;
    private bool _isActive = true;
    private string _notificationEmails = string.Empty;
    private bool _enableDownload = true;
    private bool _enableViewOnly = true;
    private bool _enableWatermark = false;

    // File rename dialog state
    private bool _showRenameFileDialog = false;
    private int _renameFileId = 0;
    private string _renameItemName = string.Empty;
    private string _renameFileExtension = string.Empty;
    private bool _renameIsFolder = false;
    private string _activeTab = "Documents";

    // ZIP extraction state
    private bool _enableZipExtraction = true;

    // File browser state
    private List<File> _files;
    private List<FolderBrowserItem> _browserItems;
    private Dictionary<int, Folder> _folderLookup = new();
    private HashSet<int> _allowedFolderIds = new();
    private int _rootFolderId;
    private int _currentFolderId;
    private string _currentFolderPath = string.Empty;
    private int _numberPerPage = 10;
    private string _sortColumn = "ModifiedOn";
    private bool _sortDescending = true;
    //private string _currentFolder;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _folders = await FolderService.GetFoldersAsync(ModuleState.SiteId);

            if (PageState.QueryString.ContainsKey("id") && int.TryParse(PageState.QueryString["id"], out int id))
            {
                await logger.LogInformation("Edit.razor - Loading DataRoom: id={DataRoomId}, ModuleId={ModuleId}", id, ModuleState.ModuleId);
                _dataRoom = await DataRoomService.GetDataRoomAsync(id, ModuleState.ModuleId);


                if (_dataRoom == null)
                {
                    await logger.LogWarning("Edit.razor - DataRoom not found or access denied: id={DataRoomId}, ModuleId={ModuleId}", id, ModuleState.ModuleId);
                }
            }

            if (_dataRoom != null)
            {
                _name = _dataRoom.Name;
                _description = _dataRoom.Description ?? string.Empty;
                _folderId = _dataRoom.FolderId;
                _isActive = _dataRoom.IsActive;
                _notificationEmails = _dataRoom.NotificationEmails ?? string.Empty;
                _enableDownload = _dataRoom.EnableDownload;
                _enableViewOnly = _dataRoom.EnableViewOnly;
                _enableWatermark = _dataRoom.EnableWatermark;
                _activityLogs = await ActivityLogService.GetActivityLogsAsync(_dataRoom.DataRoomId, ModuleState.ModuleId);
                await LoadFileNamesAsync();
                await LoadUserDisplayNamesAsync();

                // Load pager settings
                var settings = await SettingService.GetModuleSettingsAsync(ModuleState.ModuleId);
                var numberPerPageSetting = SettingService.GetSetting(settings, "NumberPerPage", "10");
                if (!int.TryParse(numberPerPageSetting, out _numberPerPage) || _numberPerPage < 1)
                {
                    _numberPerPage = 10;
                }

                // Load files and folders for the browser
                await RefreshBrowserAsync();
            }
            else
            {
                _activeTab = "Settings"; // New room defaults to settings tab
            }
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error Loading Data Room Settings {Error}", ex.Message);
            AddModuleMessage("Error loading Data Room settings.", MessageType.Error);
        }
    }

    private async Task SaveAsync()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(_name))
            {
                AddModuleMessage("Name is required.", MessageType.Warning);
                return;
            }
            if (_folderId == 0)
            {
                AddModuleMessage("Please select a folder.", MessageType.Warning);
                return;
            }

            if (_dataRoom == null)
            {
                var room = new DataRoom
                {
                    ModuleId = ModuleState.ModuleId,
                    SiteId = ModuleState.SiteId,
                    Name = _name,
                    Description = _description,
                    FolderId = _folderId,
                    IsActive = _isActive,
                    NotificationEmails = _notificationEmails,
                    EnableDownload = _enableDownload,
                    EnableViewOnly = _enableViewOnly,
                    EnableWatermark = _enableWatermark
                };
                _dataRoom = await DataRoomService.AddDataRoomAsync(room);
                await logger.LogInformation("Data Room Created {DataRoomId}", _dataRoom.DataRoomId);
            }
            else
            {
                _dataRoom.Name = _name;
                _dataRoom.Description = _description;
                _dataRoom.FolderId = _folderId;
                _dataRoom.IsActive = _isActive;
                _dataRoom.NotificationEmails = _notificationEmails;
                _dataRoom.EnableDownload = _enableDownload;
                _dataRoom.EnableViewOnly = _enableViewOnly;
                _dataRoom.EnableWatermark = _enableWatermark;
                _dataRoom = await DataRoomService.UpdateDataRoomAsync(_dataRoom);
                await logger.LogInformation("Data Room Updated {DataRoomId}", _dataRoom.DataRoomId);
            }

            // Refresh browser items after save
            await RefreshBrowserAsync();

            NavigationManager.NavigateTo(NavigateUrl());
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error Saving Data Room {Error}", ex.Message);
            AddModuleMessage("Error saving Data Room.", MessageType.Error);
        }
    }

    private async Task DeleteAsync()
    {
        try
        {
            await DataRoomService.DeleteDataRoomAsync(_dataRoom.DataRoomId, ModuleState.ModuleId);
            await logger.LogInformation("Data Room Deleted {DataRoomId}", _dataRoom.DataRoomId);
            NavigationManager.NavigateTo(NavigateUrl());
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error Deleting Data Room {DataRoomId} {Error}", _dataRoom.DataRoomId, ex.Message);
            AddModuleMessage("Error deleting Data Room.", MessageType.Error);
        }
    }

    private async Task HandleUploadAsync(int fileId)
    {
        try
        {
            await ActivityLogService.AddActivityLogAsync(new DataRoomActivityLog
            {
                DataRoomId = _dataRoom.DataRoomId,
                FileId = fileId,
                UserId = PageState.User?.UserId.ToString() ?? string.Empty,
                Action = "Upload",
                Timestamp = DateTime.UtcNow,
                IPAddress = string.Empty
            }, ModuleState.ModuleId);

            // Check if ZIP extraction is enabled and file is a ZIP
            if (_enableZipExtraction)
            {
                // Get file name to check extension
                await LoadFileNamesAsync();

                if (_fileNames.TryGetValue(fileId, out var fileName) && fileName.EndsWith(".zip", StringComparison.OrdinalIgnoreCase))
                {
                    try
                    {
                        // Call server endpoint to extract ZIP
                        var url = $"{PageState.Alias.BaseUrl}api/DataRoom/extract/{_dataRoom.DataRoomId}/{ModuleState.ModuleId}/{fileId}";
                        using (var response = await HttpClient.PutAsync(url, null))
                        {
                            if (response.IsSuccessStatusCode)
                            {
                                AddModuleMessage($"ZIP file '{fileName}' extracted successfully.", MessageType.Success);

                                // Refresh browser to show extracted files
                                await RefreshBrowserAsync();
                            }
                            else
                            {
                                var errorContent = await response.Content.ReadAsStringAsync();
                                AddModuleMessage($"Error extracting ZIP: {response.StatusCode}", MessageType.Error);
                            }
                        }

                        _folders = await FolderService.GetFoldersAsync(ModuleState.SiteId); // Refresh folder list in case new folders were created during extraction
                    }
                    catch (Exception ex)
                    {
                        await logger.LogError(ex, "Error extracting ZIP file {FileId}", fileId);
                        AddModuleMessage($"Error extracting ZIP: {ex.Message}", MessageType.Error);
                    }
                }
            }

            // Refresh log tab and browser
            _activityLogs = await ActivityLogService.GetActivityLogsAsync(_dataRoom.DataRoomId, ModuleState.ModuleId);
            await LoadUserDisplayNamesAsync();
            await RefreshCurrentFolderAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error Logging Upload {FileId} {Error}", fileId, ex.Message);
        }
    }

    private async Task DownloadZipAsync()
    {
        var url = $"{PageState.Alias.BaseUrl}api/DataRoom/zip/{_dataRoom.DataRoomId}/{ModuleState.ModuleId}?authmoduleid={ModuleState.ModuleId}";
        await JSRuntime.InvokeVoidAsync("open", url, "_blank");
    }

    private async Task LoadFileNamesAsync()
    {
        _fileNames.Clear();

        if (_dataRoom == null || _dataRoom.FolderId <= 0)
        {
            return;
        }

        var files = await FileService.GetFilesAsync(_dataRoom.FolderId);
        if (files == null)
        {
            return;
        }

        foreach (var file in files)
        {
            _fileNames[file.FileId] = file.Name;
        }
    }

    private async Task LoadUserDisplayNamesAsync()
    {
        _userDisplayNames.Clear();

        if (_activityLogs == null || !_activityLogs.Any())
        {
            return;
        }

        var userIds = _activityLogs
            .Select(l => l.UserId)
            .Where(id => !string.IsNullOrWhiteSpace(id))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        foreach (var userId in userIds)
        {
            if (!int.TryParse(userId, out var numericUserId))
            {
                _userDisplayNames[userId] = userId;
                continue;
            }

            try
            {
                var user = await UserService.GetUserAsync(numericUserId, ModuleState.SiteId);
                _userDisplayNames[userId] = !string.IsNullOrWhiteSpace(user?.DisplayName)
                    ? user.DisplayName
                    : userId;
            }
            catch
            {
                _userDisplayNames[userId] = userId;
            }
        }
    }

    private string GetFileName(int fileId)
    {
        if (fileId <= 0)
        {
            return "-";
        }

        return _fileNames.TryGetValue(fileId, out var fileName) && !string.IsNullOrWhiteSpace(fileName)
            ? fileName
            : $"#{fileId}";
    }

    private string GetUserDisplay(string userId)
    {
        if (string.IsNullOrWhiteSpace(userId))
        {
            return "-";
        }

        return _userDisplayNames.TryGetValue(userId, out var displayName) && !string.IsNullOrWhiteSpace(displayName)
            ? displayName
            : userId;
    }

    private static string GetActionBadge(string action) => action switch
    {
        "Download" => "bg-primary",
        "Upload"   => "bg-success",
        "View"     => "bg-secondary",
        _          => "bg-light text-dark border"
    };

    private void OpenRenameFileDialog(int fileId, string currentName, bool isFile = true)
    {
        _renameFileId = fileId;
        _renameIsFolder = !isFile;

        if (isFile)
        {
            // Extract extension and base name
            int dotIndex = currentName.LastIndexOf('.');
            if (dotIndex > 0)
            {
                _renameFileExtension = currentName.Substring(dotIndex);
                _renameItemName = currentName.Substring(0, dotIndex);
            }
            else
            {
                _renameFileExtension = string.Empty;
                _renameItemName = currentName;
            }
        }
        else
        {
            // Folders don't have extensions
            _renameFileExtension = string.Empty;
            _renameItemName = currentName;
        }

        _showRenameFileDialog = true;
    }

    private void CloseRenameFileDialog()
    {
        _showRenameFileDialog = false;
        _renameItemName = string.Empty;
        _renameFileExtension = string.Empty;
        _renameFileId = 0;
        _renameIsFolder = false;
    }

    private async Task RenameItemAsync()
    {
        if (string.IsNullOrWhiteSpace(_renameItemName))
        {
            AddModuleMessage("Name cannot be empty.", MessageType.Warning);
            return;
        }

        // Validate no dots in the input for files (extension protection)
        if (!_renameIsFolder && _renameItemName.Contains("."))
        {
            AddModuleMessage("Name cannot contain a period (.). The file extension will be added automatically.", MessageType.Warning);
            return;
        }

        try
        {
            string newName = string.IsNullOrEmpty(_renameFileExtension)
                ? _renameItemName
                : _renameItemName + _renameFileExtension;

            // Call server endpoint to rename file or folder
            var url = $"{PageState.Alias.BaseUrl}api/DataRoom/Rename?authmoduleid={ModuleState.ModuleId}";
            using (var response = await HttpClient.PostAsJsonAsync(url, 
                new { 
                    fileId = _renameIsFolder ? 0 : _renameFileId, 
                    folderId = _renameIsFolder ? _renameFileId : 0, 
                    dataRoomId = _dataRoom.DataRoomId, 
                    moduleId = ModuleState.ModuleId, 
                    newName = _renameItemName,
                    isFolder = _renameIsFolder
                }))
            {
                if (response.IsSuccessStatusCode)
                {
                    _showRenameFileDialog = false;
                    _renameItemName = string.Empty;
                    _renameFileExtension = string.Empty;
                    _renameFileId = 0;
                    _renameIsFolder = false;

                    // Refresh the browser to show the renamed item
                    await RefreshBrowserAsync();
                    AddModuleMessage($"Item renamed to: {newName}", MessageType.Success);
                }
                else
                {
                    var errorContent = await response.Content.ReadAsStringAsync();
                    AddModuleMessage($"Error renaming item: {response.StatusCode}", MessageType.Error);
                }
            }
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error renaming item {ItemId}", _renameFileId);
            AddModuleMessage($"Error renaming item: {ex.Message}", MessageType.Error);
        }
    }

    private void OpenFolder(int folderId)
    {
        if (!_allowedFolderIds.Contains(folderId))
        {
            return;
        }
        _currentFolderId = folderId; // Update the DataRoom's current folder for context (not necessarily needed if we rely on _currentFolderId, but keeps it in sync)

        BuildBrowserItems();

    }

    private void OpenParentFolder()
    {
        if (!CanNavigateUp)
        {
            return;
        }

        // Safe access since CanNavigateUp already validated the structure
        if (_folderLookup.TryGetValue(_currentFolderId, out var currentFolder) && 
            currentFolder.ParentId.HasValue)
        {
            var parentId = currentFolder.ParentId.Value;
            _currentFolderId = parentId;
            BuildBrowserItems();
        }
    }

    private bool CanNavigateUp =>
        _currentFolderId != _rootFolderId &&
        _folderLookup.TryGetValue(_currentFolderId, out var folder) &&
        folder.ParentId.HasValue &&
        _allowedFolderIds.Contains(folder.ParentId.Value);

    private void BuildBrowserItems()
    {
        var items = new List<FolderBrowserItem>();

        var childFolders = _folders
            .Where(f => f.ParentId == _currentFolderId && _allowedFolderIds.Contains(f.FolderId))
            .OrderBy(f => f.Name)
            .Select(f => new FolderBrowserItem
            {
                IsFolder = true,
                FolderId = f.FolderId,
                Name = f.Name
            });

        items.AddRange(childFolders);

        var currentFolderFiles = (_files ?? new List<File>())
            .Where(f => f.FolderId == _currentFolderId)
            .Select(f => new FolderBrowserItem
            {
                IsFolder = false,
                FolderId = f.FolderId,
                FileId = f.FileId,
                Name = f.Name,
                Extension = f.Extension,
                Size = f.Size,
                ModifiedOn = f.ModifiedOn
            })
            .ToList();

        // Apply sorting based on _sortColumn and _sortDescending
        currentFolderFiles = ApplySorting(currentFolderFiles);
        items.AddRange(currentFolderFiles);

        _browserItems = items;

        if (_folderLookup.TryGetValue(_currentFolderId, out var folder))
        {
            _currentFolderPath = folder.Path;
        }
        else
        {
            _currentFolderPath = "Unknown";
        }
    }

    private List<FolderBrowserItem> ApplySorting(List<FolderBrowserItem> items)
    {
        return _sortColumn switch
        {
            "Name" => _sortDescending
                ? items.OrderByDescending(x => x.Name).ToList()
                : items.OrderBy(x => x.Name).ToList(),
            "Type" => _sortDescending
                ? items.OrderByDescending(x => x.Extension ?? "").ToList()
                : items.OrderBy(x => x.Extension ?? "").ToList(),
            "Size" => _sortDescending
                ? items.OrderByDescending(x => x.Size).ToList()
                : items.OrderBy(x => x.Size).ToList(),
            "ModifiedOn" => _sortDescending
                ? items.OrderByDescending(x => x.ModifiedOn).ToList()
                : items.OrderBy(x => x.ModifiedOn).ToList(),
            _ => _sortDescending
                ? items.OrderByDescending(x => x.ModifiedOn).ToList()
                : items.OrderBy(x => x.ModifiedOn).ToList()
        };
    }

    private void OnSortColumnChanged(string columnName)
    {
        if (_sortColumn == columnName)
        {
            // If clicking the same column, toggle the sort direction
            _sortDescending = !_sortDescending;
        }
        else
        {
            // If clicking a different column, set it as the new sort column with descending order
            _sortColumn = columnName;
            _sortDescending = true;
        }

        BuildBrowserItems();
    }

    private string FormatSize(int bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        double len = bytes;
        int order = 0;

        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }

        return $"{len:0.##} {sizes[order]}";
    }

    private string GetFileTypeIcon(string extension)
    {
        return extension.ToLower() switch
        {
            "docx" or "doc" => "_content/GIBS.Module.DataRoom/icons/word.svg",
            "xlsx" or "xls" => "_content/GIBS.Module.DataRoom/icons/excel.svg",
            "pptx" or "ppt" => "_content/GIBS.Module.DataRoom/icons/powerpoint.svg",
            _ => "_content/GIBS.Module.DataRoom/icons/document.svg"
        };
    }

    private string GetFileTypeLabel(string extension)
    {
        return extension.ToLower() switch
        {
            "docx" or "doc" => "Word Document",
            "xlsx" or "xls" => "Excel Spreadsheet",
            "pptx" or "ppt" => "PowerPoint Presentation",
            _ => "Document"
        };
    }

    private async Task DownloadFileAsync(int fileId, string fileName)
    {
        try
        {
            if (_dataRoom == null) return;

            if (PageState.User != null)
            {
                await ActivityLogService.AddActivityLogAsync(new DataRoomActivityLog
                {
                    DataRoomId = _dataRoom.DataRoomId,
                    FileId = fileId,
                    UserId = PageState.User.UserId.ToString(),
                    Action = "Download",
                    Timestamp = DateTime.UtcNow,
                    IPAddress = string.Empty
                }, ModuleState.ModuleId);
            }

            var uri = NavigationManager.GetUriWithQueryParameter("download", $"{fileId}");
            NavigationManager.NavigateTo(uri, forceLoad: true);
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error downloading file {FileId}", fileId);
            AddModuleMessage("Error downloading file.", MessageType.Error);
        }
    }

    private async Task RefreshBrowserAsync()
    {
        if (_dataRoom == null || _dataRoom.FolderId <= 0)
        {
            return;
        }

        try
        {
            _rootFolderId = _dataRoom.FolderId;
            _currentFolderId = _rootFolderId;

            _folders = await FolderService.GetFoldersAsync(ModuleState.SiteId);
            _folderLookup = _folders.ToDictionary(f => f.FolderId);

            _files = await GetFilesFromFolderHierarchyAsync(_rootFolderId, _folders);
            BuildBrowserItems();
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error loading files and folders");
            AddModuleMessage("Error loading files and folders.", MessageType.Error);
        }
    }

    private async Task RefreshCurrentFolderAsync()
    {
        if (_dataRoom == null || _dataRoom.FolderId <= 0)
        {
            return;
        }

        try
        {
            // Only reload files, preserving folder structure and current location
            _files = await GetFilesFromFolderHierarchyAsync(_rootFolderId, _folders);
            BuildBrowserItems();
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error loading files");
            AddModuleMessage("Error loading files.", MessageType.Error);
        }
    }

    private async Task DeleteFile(int fileId)
    {
        try
        {
            if (_dataRoom == null) return;

            var request = new
            {
                fileId = fileId,
                dataRoomId = _dataRoom.DataRoomId,
                moduleId = ModuleState.ModuleId
            };

            var response = await HttpClient.PostAsJsonAsync($"/api/DataRoom/DeleteFile", request);

            if (response.IsSuccessStatusCode)
            {
                _showRenameFileDialog = false;

                // Refresh the browser to show the deleted item is gone
                await RefreshBrowserAsync();
                AddModuleMessage($"File deleted successfully.", MessageType.Success);
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                AddModuleMessage($"Error deleting file: {response.StatusCode}", MessageType.Error);
            }
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error deleting file {FileId}", fileId);
            AddModuleMessage($"Error deleting file: {ex.Message}", MessageType.Error);
        }
    }

    private async Task<List<File>> GetFilesFromFolderHierarchyAsync(int rootFolderId, List<Folder> folders)
    {
        var childrenByParent = folders
            .Where(f => f.ParentId.HasValue)
            .GroupBy(f => f.ParentId.Value)
            .ToDictionary(g => g.Key, g => g.Select(f => f.FolderId).ToList());

        var folderIds = new HashSet<int> { rootFolderId };
        var queue = new Queue<int>();
        queue.Enqueue(rootFolderId);

        while (queue.Count > 0)
        {
            var currentFolderId = queue.Dequeue();
            if (!childrenByParent.TryGetValue(currentFolderId, out var childIds))
            {
                continue;
            }

            foreach (var childId in childIds)
            {
                if (folderIds.Add(childId))
                {
                    queue.Enqueue(childId);
                }
            }
        }

        _allowedFolderIds = folderIds;

        var files = new List<File>();
        foreach (var folderId in folderIds)
        {
            var folderFiles = await FileService.GetFilesAsync(folderId);
            if (folderFiles != null)
            {
                files.AddRange(folderFiles);
            }
        }

        return files
            .OrderBy(f => f.Name)
            .ToList();
    }

    private class FolderBrowserItem
    {
        public bool IsFolder { get; set; }
        public int FolderId { get; set; }
        public int FileId { get; set; }
        public string Name { get; set; }
        public string Extension { get; set; }
        public int Size { get; set; }
        public DateTime ModifiedOn { get; set; }
    }
